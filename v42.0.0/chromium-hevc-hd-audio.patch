+bool FFmpegAudioDecoder::DecodeTrueHDBuffer(const DecoderBuffer& buffer) {
+  DCHECK(!truehd_buffer_.empty());
+
+  // Guard against a pathologically large accumulation before the narrowing
+  // cast to int required by av_new_packet().
+  if (truehd_buffer_.size() > static_cast<size_t>(INT_MAX)) {
+    MEDIA_LOG(ERROR, media_log_)
+        << "TrueHD/MLP accumulation buffer overflow.";
+    FlushTrueHDBuffer();
+    return false;
+  }
+
+  // Assemble the accumulated subframes into a single FFmpeg packet. Memory
+  // is owned by FFmpeg and freed via av_packet_free() below.
+  AVPacket* assembled = av_packet_alloc();
+  if (!assembled) {
+    MEDIA_LOG(ERROR, media_log_)
+        << "Failed to allocate assembled TrueHD/MLP packet.";
+    FlushTrueHDBuffer();
+    return false;
+  }
+
+  if (av_new_packet(assembled,
+                    static_cast<int>(truehd_buffer_.size())) < 0) {
+    MEDIA_LOG(ERROR, media_log_)
+        << "Failed to allocate assembled TrueHD/MLP packet data.";
+    av_packet_free(&assembled);
+    FlushTrueHDBuffer();
+    return false;
+  }
+
+  memcpy(assembled->data, truehd_buffer_.data(), truehd_buffer_.size());
+  // Use the PTS of the first subframe in the group as the packet timestamp.
+  // DTS and duration are left unset; FFmpeg derives them from the bitstream.
+  assembled->pts = truehd_buffer_pts_;
+  assembled->dts = AV_NOPTS_VALUE;
+  assembled->duration = AV_NOPTS_VALUE;
+
+  bool decoded_frame_this_loop = false;
+  FFmpegDecodingLoop::DecodeStatus decode_status =
+      decoding_loop_->DecodePacket(
+          assembled,
+          base::BindRepeating(&FFmpegAudioDecoder::OnNewFrame,
+                              base::Unretained(this), std::cref(buffer),
+                              &decoded_frame_this_loop));
+  av_packet_free(&assembled);
+  // Always clear the accumulation buffer after a flush attempt, regardless of
+  // whether decode succeeded, to prevent stale data carrying into future frames.
+  FlushTrueHDBuffer();
+
+  if (decode_status == FFmpegDecodingLoop::DecodeStatus::kSendPacketFailed) {
+    MEDIA_LOG(ERROR, media_log_)
+        << "Failed to send assembled TrueHD/MLP packet for decoding: "
+        << buffer.AsHumanReadableString();
+    return false;
+  }
+  if (decode_status ==
+      FFmpegDecodingLoop::DecodeStatus::kFrameProcessingFailed) {
+    // OnNewFrame() has already issued a MEDIA_LOG for this.
+    return false;
+  }
+  if (!decoded_frame_this_loop) {
+    discard_helper_->ProcessBuffers(
+        AudioDiscardHelper::TimeInfo::FromBuffer(buffer), nullptr);
+  }
+  return true;
+}
